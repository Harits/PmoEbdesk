# OpenProject API Configuration
# Replace these values with your actual OpenProject credentials and configurations
OPENPROJECT_HOST=https://your-openproject-domain.com
OPENPROJECT_API_KEY=your_openproject_api_key_here
# If using basic auth instead of apikey (apikey:your_openproject_api_key)
# OPENPROJECT_USERNAME=apikey
# OPENPROJECT_PASSWORD=your_openproject_api_key_here
